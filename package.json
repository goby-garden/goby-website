{
  "name": "goby",
  "type":"module",
  "version": "0.0.5",
  "description": "A web app that will enrich Are.na channels with more complex ontology-building tools",
  "main": "index.js",
  "scripts": {
    "svelte:dev": "cd sveltekit && vite build --watch --logLevel silent",
    "svelte:build": "cd sveltekit && vite build",
    "11ty:dev": "npx @11ty/eleventy --config=.eleventy.cjs --serve",
    "11ty:build":"npx @11ty/eleventy --config=.eleventy.cjs",
    "build":"npm run svelte:build && npm run 11ty:build",
    "dev":"NODE_ENV=development concurrently -n=s,e -c='#ff3d7b','#0ff5b4' \"npm run svelte:dev\" \"npm run 11ty:dev\"",
    "netlify": "netlify dev",
    "start": "npm run netlify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nchilla/goby.git"
  },
  "author": "Nico Chilla",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nchilla/goby/issues"
  },
  "homepage": "https://github.com/nchilla/goby#readme",
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "concurrently": "^9.1.2",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "archieml": "^0.5.0",
    "d3": "^7.4.0",
    "js-yaml": "^4.1.0",
    "marked": "^4.0.7"
  }
}
